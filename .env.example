# FraudLens Phase 1 local integration example
# Copy this file to `.env` for local use and replace placeholders only on your machine.
# Do not commit real credentials.

# External runtime source
EXTERNAL_RUNTIME_REPOSITORY=https://github.com/Shreyash2942/Data-Lab.git

# Airflow
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=<set-locally>
AIRFLOW_PASSWORD=<set-locally>

# PostgreSQL metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=<set-locally>
POSTGRES_USER=<set-locally>
POSTGRES_PASSWORD=<set-locally>

# MinIO object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=<set-locally>
MINIO_SECRET_KEY=<set-locally>
MINIO_DEFAULT_BUCKET=fraudlens-raw

# Monitoring
PROMETHEUS_BASE_URL=http://localhost:9090
GRAFANA_BASE_URL=http://localhost:3000

# Lineage
MARQUEZ_BASE_URL=http://localhost:3003
OPENLINEAGE_URL=http://localhost:5000
