# Stage 1 and Stage 2 local secret contract

# Generic profile selector
PHASE3_ENV=local

# Local service checks
TRINO_HOST=localhost
TRINO_PORT=8085
MINIO_ENDPOINT=http://localhost:9009
MINIO_BUCKET=fraudlensdata

# Cloud / Snowflake (set when PHASE3_ENV=cloud)
SNOWFLAKE_ACCOUNT=<set-locally>
SNOWFLAKE_USER=<set-locally>
SNOWFLAKE_PASSWORD=<set-locally>
SNOWFLAKE_ROLE=FRAUDLENS_ENGINEER_ROLE
SNOWFLAKE_WAREHOUSE=FRAUDLENS_WH_XS
SNOWFLAKE_DATABASE=FRAUDLENS
